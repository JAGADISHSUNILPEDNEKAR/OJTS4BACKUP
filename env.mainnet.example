# --- Base Services ---
DATABASE_URL=postgresql+asyncpg://origin:production_password@production.db.internal:5432/origin_db
REDIS_URL=redis://production.redis.internal:6379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=production.kafka.internal:9092

# --- Crypto Service (Mainnet) ---
BITCOIN_RPC_URL=http://production.bitcoincore.internal:8332
BITCOIN_RPC_USER=admin_mainnet
BITCOIN_RPC_PASS=secure_mainnet_rpc_password

# --- Escrow Service ---
ESCROW_MULTISIG_REQUIRED=2
ESCROW_MULTISIG_TOTAL=3

# --- Email Notifications ---
SENDGRID_API_KEY=SG.production_key_here

# --- IoT/Feature Storage ---
AWS_ACCESS_KEY_ID=AKIA_PRODUCTION
AWS_SECRET_ACCESS_KEY=secure_prod_secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=origin-production-manifests
